# git-ai configuration. Copy this file to .env and fill it in.
# PROVIDER selects the model backend: "ollama" (local) or "openai" (cloud).
PROVIDER=ollama

# --- Ollama (local, offline) ---
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=gemma3:4b

# --- OpenAI-compatible (cloud) ---
# Bynara is an OpenAI-compatible router. Sign up to get your own key:
#   https://router.bynara.id/register?ref=NMAP6F9D
LLM_BASE_URL=https://router.bynara.id/v1
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
